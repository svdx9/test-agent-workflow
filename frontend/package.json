{
  "name": "conjugate-cc-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "openapi-typescript ../docs/schema/v1/conjugate.yaml -o src/shared/api/v1.d.ts"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.4",
    "openapi-fetch": "^0.14.0",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin": "^1.0.1",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^27.0.0",
    "openapi-typescript": "^7.8.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "solid-devtools": "^0.34.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.3",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^3.2.4"
  }
}
